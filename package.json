{
  "name": "chalo-app",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node server/index.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "start:win": "set NODE_ENV=production && node server/index.js",
    "build:mobile": "vite build --mode mobile",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "mobile:build": "npm run build:mobile && npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "concurrently": "^9.0.0",
    "sharp": "^0.34.5",
    "vite": "^6.0.0"
  }
}
